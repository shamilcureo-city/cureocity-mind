// Cureocity Mind — Prisma schema
//
// Scope: Sprint 1 models only. Each subsequent service adds its own models
// via its own migration as the sprint lands. The plan (§ 5) ships:
//   Sprint 1 (this file): Psychologist, Client, Consent, Session, AuditLog
//   Sprint 2: TherapyNote, NoteDraft, AudioChunk, GeminiCallLog
//   Sprint 3: ModalityState, ModalityTransition
//   Sprint 4: AffectFeature
//   Sprint 5: ExerciseAssignment, ExerciseResponse, JournalEntry, MoodLog
//   Sprint 7: NoteEdit (per gap G11)
//   Sprint 9: encryption columns (per gap G10), admin role (per gap G9)
//
// PRD gap resolutions applied here:
//   G5: Session.status enum extended with CANCELLED, NO_SHOW, RESCHEDULED
//   G7: no supervisor/co-signature workflow in V1 (pilot uses senior RCI therapists only)
//   G13: ConsentScope.CROSS_BORDER_PROCESSING covers Gemini Pro global pass

generator client {
  provider        = "prisma-client-js"
  // driverAdapters enables @prisma/adapter-neon for the Vercel BFF
  // (apps/api). NestJS services still use the standard connection
  // pool — the adapter is request-scoped + opt-in per client.
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Psychologist — the therapist tenant. Authenticated via Firebase phone OTP.
// ============================================================================

enum PsychologistStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  OFFBOARDED
}

// Role gates access to /api/v1/admin/* endpoints. THERAPIST is the
// default (all clinical surfaces). ADMIN can read audit logs and
// trigger DSR fulfilment. There is no "super admin" tier in V1; admin
// is granted out-of-band by direct DB update + audit row. Gap G9, Sprint 9.
enum PsychologistRole {
  THERAPIST
  ADMIN
}

// Sprint DV1 — product vertical discriminator. One system, two faces:
// THERAPIST (psychotherapy) vs DOCTOR (super-specialty OPD scribe). See
// docs/DOCTOR_VERTICAL.md. Append-only; never reorder existing values.
enum PractitionerVertical {
  THERAPIST
  DOCTOR
}

model Psychologist {
  id            String             @id @default(cuid())
  firebaseUid   String             @unique
  email         String             @unique
  fullName      String
  phone         String             @unique
  rciNumber     String             @unique
  rciVerifiedAt DateTime?
  status        PsychologistStatus @default(PENDING_VERIFICATION)
  role          PsychologistRole   @default(THERAPIST)

  /// First-run welcome dismissed — durable, per-therapist replacement for
  /// the per-device localStorage flag. Set via POST /psychologists/me/welcome.
  hasSeenWelcome Boolean @default(false)

  /// Sprint DV1 — product vertical (THERAPIST | DOCTOR). Drives landing,
  /// nav, prompt + contract selection. See docs/DOCTOR_VERTICAL.md.
  vertical         PractitionerVertical @default(THERAPIST)
  /// Sprint DV1 — doctor credential (NMC / state medical council reg).
  /// NULL for therapists, who use rciNumber instead.
  medicalRegNumber String?              @unique
  /// Sprint DV1 — doctor specialty (e.g. "Cardiology"). NULL for therapists.
  specialty        String?

  // Public directory profile fields. All optional so existing rows
  // continue to validate; the directory hides rows where bio is null.
  headline              String?
  bio                   String?  @db.Text
  photoUrl              String?
  specialties           String[] @default([])
  languages             String[] @default([])
  modalities            String[] @default([])
  yearsOfExperience     Int?
  locationCity          String?
  locationProvince      String?
  sessionFeeInr         Int?
  isAcceptingNewClients Boolean  @default(true)

  // Sprint 18 — therapist preferences.
  /// ISO 639-1 default output language for new notes / briefs.
  defaultOutputLanguage String       @default("en")
  /// Default modality when creating a session for a client without a preferredModality.
  defaultModality       String?
  /// Sprint DS11.7-fu — a doctor's preferred capture pipeline for a new
  /// consult (LIVE is the product default; a doctor who works in a noisy OPD
  /// or without a reliable mic can pre-select DICTATE/UPLOAD). NULL = LIVE.
  defaultCaptureMode    CaptureMode?
  /// Secondary email for account recovery if phone-OTP fails. Verified separately.
  backupEmail           String?

  /// Sprint 31 — set once the auto-provisioned placeholder fields
  /// (email/RCI/fullName from POST /api/v1/auth/session) have been
  /// replaced via /app/onboarding. Page guards bounce sessions with a
  /// null timestamp to the onboarding form.
  onboardingCompletedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  clients             Client[]
  sessions            Session[]
  auditLogs           AuditLog[]
  consentsTaken       Consent[]
  modalityStates      ModalityState[]
  exerciseAssignments ExerciseAssignment[]
  tenantKeys          PsychologistTenantKey[]
  bookings            Booking[]
  intakeMatches       IntakeSubmission[]
  noteTemplates       NoteTemplate[]
  clinicalReports     ClinicalReport[]
  clientDiagnoses     ClientDiagnosis[]
  treatmentPlans      TreatmentPlan[]
  therapyScripts      TherapyScript[]
  patientShares       PatientShare[]
  preSessionBriefs    PreSessionBrief[]
  conceptualMaps      ClientConceptualMap[]
  instrumentResponses InstrumentResponse[]
  safetyPlans         SafetyPlan[]
  webauthnCredentials WebAuthnCredential[]
  clinicMemberships   ClinicMembership[]

  /// Sprint 56 (Lever 3a) — acquisition attribution captured at signup.
  /// Free-form JSON; shape is { utm_source, utm_medium, utm_campaign,
  /// referrer } with every field optional. Read by the admin funnel
  /// dashboard. NULL for pre-S56 rows + any row whose signup happened
  /// without UTM params on the landing URL.
  acquisitionUtm Json?

  @@index([status])
  @@index([role])
  @@index([isAcceptingNewClients])
  @@index([onboardingCompletedAt])
  @@map("psychologists")
}

// ============================================================================
// WebAuthnCredential — Sprint 18. One row per (psychologist, registered
// platform authenticator). The presence of ≥1 non-revoked credential
// flips the sign route from "assertion optional" to "assertion required".
// Signature verification ladder documented in
// packages/contracts/src/webauthn.ts.
// ============================================================================

model WebAuthnCredential {
  id             String @id @default(cuid())
  psychologistId String

  /// base64url of cred.rawId — globally unique across all credentials.
  credentialId String @unique
  /// COSE public key bytes (base64url).
  publicKey    String @db.Text

  /// Counter the authenticator increments per use; rolling-back is replay.
  signCount Int @default(0)

  /// Comma-separated transport hints captured at registration.
  /// Persisted as `String[]` since Postgres supports it natively.
  transports String[] @default([])

  /// User-friendly label ("MacBook Touch ID").
  label String?

  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId, revokedAt])
  @@map("webauthn_credentials")
}

/// Sprint 39 — multi-tenant foundation. A Clinic is the org unit a
/// therapist belongs to. Solo practitioners get an auto-created SOLO
/// clinic (a clinic of one); GROUP clinics seat several therapists.
///
/// PHASE 1 (this sprint) is additive only: clinics + memberships exist
/// and every therapist is an OWNER of their own clinic, but client /
/// session / note rows stay therapist-owned and every existing query is
/// unchanged. PHASE 2 (cross-therapist visibility, clinic-admin views,
/// shared records) is deliberately deferred — it needs product
/// decisions on clinical confidentiality boundaries.
model Clinic {
  id   String     @id @default(cuid())
  name String
  kind ClinicKind @default(SOLO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships ClinicMembership[]

  @@map("clinics")
}

enum ClinicKind {
  SOLO
  GROUP
}

enum ClinicRole {
  OWNER
  ADMIN
  MEMBER
}

model ClinicMembership {
  id             String     @id @default(cuid())
  clinicId       String
  psychologistId String
  role           ClinicRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([clinicId, psychologistId])
  @@index([psychologistId])
  @@map("clinic_memberships")
}

/// Sprint 37 — pilot invite codes. When PILOT_INVITE_REQUIRED=true, a
/// new therapist's first sign-in (the auto-provision signup in
/// /api/v1/auth/session) requires a valid, unredeemed code. Minted by
/// admins; multi-use via maxUses (one code can seat a whole cohort).
model PilotInviteCode {
  id    String  @id @default(cuid())
  /// The human-shareable code (uppercase alphanumeric). Unique.
  code  String  @unique
  /// Admin note — who/what this code is for.
  label String?

  /// How many signups this code may seat, and how many it has seated.
  maxUses   Int @default(1)
  usedCount Int @default(0)

  createdByPsychologistId String?
  expiresAt               DateTime?
  revokedAt               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([revokedAt])
  @@map("pilot_invite_codes")
}

enum BookingStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model Booking {
  id           String        @id @default(cuid())
  therapistId  String
  patientName  String
  patientEmail String
  patientPhone String
  preferredAt  DateTime
  message      String?       @db.Text
  status       BookingStatus @default(PENDING)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  therapist Psychologist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, status])
  @@index([status, createdAt])
  @@map("bookings")
}

enum IntakeUrgency {
  LOW
  MEDIUM
  HIGH
}

enum IntakeMode {
  IN_PERSON
  ONLINE
  EITHER
}

enum IntakeStatus {
  NEW
  REVIEWED
  MATCHED
  CLOSED
}

model IntakeSubmission {
  id                  String        @id @default(cuid())
  patientName         String
  patientEmail        String
  patientPhone        String
  concerns            String[]      @default([])
  notes               String?       @db.Text
  preferredModality   String?
  preferredLanguage   String?
  mode                IntakeMode    @default(EITHER)
  urgency             IntakeUrgency @default(MEDIUM)
  status              IntakeStatus  @default(NEW)
  assignedTherapistId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  matchedAt DateTime?

  assignedTherapist Psychologist? @relation(fields: [assignedTherapistId], references: [id])

  @@index([status, createdAt])
  @@index([assignedTherapistId])
  @@map("intake_submissions")
}

// ============================================================================
// PsychologistTenantKey — wrapped Data Encryption Key, one active row per
// psychologist tenant. Per § 6.6 of the execution plan: 90-day rotation.
// Older rows are kept (not deleted) so historical ciphertext can still be
// decrypted on read until those rows are rotated forward in a background
// task. Gap G10, Sprint 9 PR 3.
// ============================================================================

model PsychologistTenantKey {
  id             String @id @default(cuid())
  psychologistId String

  /// KMS-side identifier (AWS KMS CMK id, or 'local-dev-kms-v1' for dev).
  kmsKeyId   String
  /// Base64-encoded wrapped DEK as returned by IKmsProvider.generateDataKey.
  wrappedKey String    @db.Text
  /// Active rows are used for new writes; old rows are used for decrypt only.
  /// On rotation, the previous active row's retiredAt is set.
  retiredAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId, retiredAt])
  @@map("psychologist_tenant_keys")
}

// ============================================================================
// Client — the patient under care. Strictly owned by one Psychologist; row-level
// isolation enforced at the service layer via psychologistId filter.
// ============================================================================

enum ClientStatus {
  ACTIVE
  PAUSED
  DISCHARGED
  TRANSFERRED
}

model Client {
  id             String @id @default(cuid())
  psychologistId String

  // Firebase UID for the CLIENT user (separate from Psychologist.firebaseUid).
  // Set when the client claims their account via QR/link (Sprint 8). Until then
  // null, and the patient-app side of continuity endpoints is unreachable.
  clientFirebaseUid String? @unique

  // PII — Sprint 9 PR 3 (gap G10). S32 Phase 2 completed the cutover: the
  // legacy plaintext columns (fullName / contactPhone / contactEmail) were
  // DROPPED once every read resolved through client-pii.ts and PII moved to
  // Google Cloud KMS envelope encryption. Only the encrypted twins remain;
  // all reads go through resolveClientPii, all writes set the *Encrypted cols.
  dateOfBirth DateTime? @db.Date

  /// Envelope-encrypted contactPhone — format documented in @cureocity/crypto.
  /// Sole store for the value (plaintext column dropped, S32 Phase 2).
  contactPhoneEncrypted String?
  contactEmailEncrypted String?

  /// Envelope-encrypted fullName — Sprint 54. The patient's name is the
  /// highest-sensitivity PII field. Sole store since the S32 Phase 2 plaintext
  /// drop.
  fullNameEncrypted String?

  // Clinical context (free text in V1; structured assessment in Sprint 5)
  presentingConcerns String?
  preferredModality  String?

  /// Sprint TSC — questions the therapist ticked on the copilot decision
  /// board to carry into the NEXT session. JSON array of
  /// { question, rationale, sourceSessionId, carriedAt }. Replaced wholesale
  /// on each save; woven into the pre-session brief's case digest.
  carriedQuestions Json?

  /// Doctor vertical — Sprint DV8. The patient's linked ABHA address /
  /// number (Ayushman Bharat Health Account), set when the doctor pushes
  /// to the patient's ABDM PHR. Null until linked.
  abhaAddress String?

  status ClientStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Patient-facing language preference. Sprint 13 introduces this as
  // ISO 639-1; defaults to "en". Patient portal + sent materials use
  // this. Therapist UI session start picks up this value as default.
  preferredLanguage String @default("en")

  // Sprint 16 — the client's typical spoken languages. Therapist sets
  // this when creating the client (optional). Pass 1 uses it as a
  // soft hint for transcription; Pass 4 uses it to choose the
  // verbatim "therapistSays" language so the therapist reads aloud
  // in something the client understands. Empty when unset.
  spokenLanguages String[] @default([])

  // Sprint 48 — the showcase "Example" client a therapist can seed in
  // one click to see the full Journey / reliable-change / Progress
  // Report arc without recording six real sessions. Demo rows are
  // badged "Example" in the UI and excluded from every metric, the
  // competency rollups, and the trial session cap.
  isDemo Boolean @default(false)

  psychologist        Psychologist             @relation(fields: [psychologistId], references: [id])
  consents            Consent[]
  sessions            Session[]
  modalityState       ModalityState?
  exerciseAssignments ExerciseAssignment[]
  moodLogs            MoodLog[]
  journalEntries      JournalEntry[]
  claimTokens         ClientClaimToken[]
  pushSubscriptions   ClientPushSubscription[]
  nominations         ClientNomination[]
  erasureRequests     ClientErasureRequest[]
  grievances          ClientGrievance[]
  clinicalReports     ClinicalReport[]
  diagnoses           ClientDiagnosis[]
  treatmentPlans      TreatmentPlan[]
  therapyScripts      TherapyScript[]
  patientShares       PatientShare[]
  preSessionBriefs    PreSessionBrief[]
  conceptualMaps      ClientConceptualMap[]
  caseConsults        CaseConsult[]
  instrumentResponses InstrumentResponse[]
  safetyPlans         SafetyPlan[]
  treatmentEpisodes   TreatmentEpisode[]
  assessmentItems     AssessmentItem[]
  // Doctor vertical — Sprint DV7. Chronic-disease reading series.
  clinicalReadings    ClinicalReading[]

  @@index([psychologistId, status])
  @@index([psychologistId, deletedAt])
  @@index([psychologistId, isDemo])
  @@map("clients")
}

// ============================================================================
// DSR rows — Sprint 9 PR 2.
// One row per client request under DPDP Act Section 14 (right to
// nomination), Section 15 (erasure), and Section 16 (grievance). All
// are append-only; the admin fulfilment side updates status/resolvedAt
// rather than mutating the original payload.
// ============================================================================

enum DsrErasureStatus {
  PENDING
  APPROVED
  REJECTED
  FULFILLED
}

enum DsrGrievanceStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  CLOSED
}

model ClientNomination {
  id       String @id @default(cuid())
  clientId String

  /// Nominee's display name (the trusted person who can act on the
  /// client's data rights if the client is unable to).
  nomineeName     String
  nomineeRelation String
  nomineePhone    String
  nomineeEmail    String?

  /// Optional clause the client wants to attach (e.g. "only in case
  /// of medical incapacity").
  notes String? @db.Text

  /// Marking superseded=true when the client files a new nomination
  /// keeps the historical record without deleting it.
  supersededAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, supersededAt])
  @@map("client_nominations")
}

model ClientErasureRequest {
  id       String           @id @default(cuid())
  clientId String
  status   DsrErasureStatus @default(PENDING)

  /// Free-text reason the client supplied.
  reason String? @db.Text

  /// Admin who acted on it (null until reviewed). FK kept loose
  /// because admins may be soft-deleted later.
  resolvedByPsychologistId String?
  resolvedAt               DateTime?
  resolutionNotes          String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([status, createdAt])
  @@map("client_erasure_requests")
}

model ClientGrievance {
  id       String             @id @default(cuid())
  clientId String
  status   DsrGrievanceStatus @default(OPEN)

  /// Subject + free-text body. PII is possible here; treated as
  /// sensitive same as JournalEntry.content (Sprint 9 PR 3 encryption).
  subject String
  body    String @db.Text

  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolutionNotes String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([status, createdAt])
  @@map("client_grievances")
}

// ============================================================================
// ClientPushSubscription — one row per (client, device) Web Push
// endpoint. The patient PWA POSTs a fresh subscription when the user
// grants notification permission; we use it to fan-out adherence
// reminders. Sprint 8 PR 4.
// ============================================================================

model ClientPushSubscription {
  id       String @id @default(cuid())
  clientId String

  // The endpoint URL is unique across all push services (Mozilla,
  // Google, Apple). Use it as the natural key for upserts on re-grant.
  endpoint String @unique

  /// base64url p256dh key
  p256dh String
  /// base64url auth secret
  auth   String

  /// Best-effort device label from the UA at subscribe time.
  userAgent String?

  /// 410 (Gone) / 404 from the push service marks the row revoked;
  /// scheduler skips revoked rows. Re-subscribing on the same endpoint
  /// resets revokedAt to null via upsert.
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, revokedAt])
  @@map("client_push_subscriptions")
}

// ============================================================================
// ClientClaimToken — single-use, short-lived token issued by a psychologist
// so a client can pair their Firebase phone OTP account to a Client row.
// Generated after the first session, surfaced as a QR (printed handout) or
// shareable link. Sprint 8 PR 1.
// ============================================================================

model ClientClaimToken {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  // 22-char base64url of 16 random bytes (~128 bits of entropy). Unique
  // across all rows; the redeem endpoint looks up by token directly.
  token String @unique

  issuedAt  DateTime @default(now())
  expiresAt DateTime

  redeemedAt            DateTime?
  redeemedByFirebaseUid String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, expiresAt])
  @@map("client_claim_tokens")
}

// ============================================================================
// Consent — granular, scoped, versioned. Audit log writes on every state change.
// ============================================================================

enum ConsentScope {
  AUDIO_RECORDING
  AI_NOTE_GENERATION
  CROSS_BORDER_PROCESSING
  DATA_RETENTION_EXTENDED
}

enum ConsentStatus {
  GRANTED
  WITHDRAWN
  EXPIRED
}

enum ConsentCaptureChannel {
  IN_PERSON
  REMOTE_LINK
  EMAIL
}

model Consent {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  scope         ConsentScope
  status        ConsentStatus
  scriptVersion String
  capturedVia   ConsentCaptureChannel

  grantedAt   DateTime
  withdrawnAt DateTime?
  expiresAt   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id])
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])

  @@index([clientId, scope, status])
  @@index([psychologistId, createdAt])
  @@map("consents")
}

// ============================================================================
// Session — created in Sprint 1, populated with audio/transcript/notes by
// scribe-service in Sprint 2. Phase tracking added by modality-workflow in
// Sprint 3. Transcript field is added by scribe-service migration.
// ============================================================================

/// Sprint DS11.3 — the doctor consult's capture pipeline.
enum CaptureMode {
  LIVE
  DICTATE
  UPLOAD
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED // gap G5
  NO_SHOW // gap G5
  RESCHEDULED // gap G5
}

enum SessionModality {
  CBT
  EMDR
  // Sprint 19 — expanded evidence-based approaches. The old "OTHER"
  // bucket collapsed every non-CBT/EMDR practice into one tag; this
  // distinguishes the common ones so the recommender + competency
  // dashboard can attribute work correctly.
  ACT
  IFS
  PSYCHODYNAMIC
  MI
  MBCT
  SUPPORTIVE
  /// First-session intake (assessment + history + working hypothesis).
  /// Auto-assigned by the session-defaults cascade when no prior
  /// COMPLETED session exists and no confirmed TreatmentPlan is on
  /// file. Pass 2 produces an IntakeNoteV1 instead of a SOAP note
  /// when modality is INTAKE.
  INTAKE
  OTHER
}

/// Sprint 19 — coarse session classification computed server-side at
/// create time from cumulative state. Drives Pass 2/3 prompt branches
/// (intake-note vs treatment-note vs review-with-verdict).
enum SessionKind {
  INTAKE
  TREATMENT
  REVIEW
}

model Session {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  /// Sprint 19 made this nullable. The session-defaults cascade
  /// computes a default (TreatmentPlan.body.modality →
  /// Client.preferredModality → Psychologist.defaultModality →
  /// SessionModality.INTAKE) so the create route always has a value
  /// to write — but the column is nullable so older rows + future
  /// "decide later" flows aren't blocked at the DB level.
  modality    SessionModality?
  /// Sprint DS11.3 — how the encounter was captured (doctor vertical).
  /// Written at capture start: LIVE by the live-token route; DICTATE /
  /// UPLOAD by the batch capture paths (DS11.7). Null = pre-DS11 rows
  /// and therapist sessions.
  captureMode CaptureMode?
  /// Sprint 19 — session classification driving Pass 2/3 prompt
  /// branches. Defaults to TREATMENT for back-compat with rows
  /// inserted before this migration.
  kind        SessionKind      @default(TREATMENT)
  status      SessionStatus    @default(SCHEDULED)

  /// Sprint 70 — the note template chosen for this session's note. Scalar FK
  /// (no relation, like Letter) to a NoteTemplate; null = the built-in SOAP
  /// structure. When set, Pass 2 also produces `templateSections` shaped to
  /// the template, in addition to the authoritative SOAP fields.
  noteTemplateId String?

  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?

  // Phase snapshot — opaque JSON, populated by modality-workflow-service (Sprint 3).
  phaseSnapshot Json?

  // Consent ack captured at /sessions/:id/consent — array of { scope, scriptVersion, ackedAt }.
  // Snapshot at session start, separate from client-level Consent rows so we
  // have an audit trail even if client consents change later. (Sprint 2)
  consentSnapshot Json?

  // Per-session output language for Pass 2/3/4 NARRATIVE text (notes,
  // clinical brief, therapy-script rationale). Sprint 13 introduced
  // the field as a single string; Sprint 16 keeps it as the OUTPUT
  // (therapist-facing) language and adds spokenLanguages alongside.
  // ISO 639-1; defaults to "en".
  language String @default("en")

  // Sprint 16 — spoken languages detected by Pass 1, sorted by
  // prevalence. Empty until Pass 1 completes. Real Indian sessions
  // are usually code-mixed (Manglish, Hinglish, etc.) so this is an
  // ARRAY rather than a single value.
  // Examples: ["en"], ["ml", "en"], ["hi", "en"], ["en", "ml", "hi"].
  spokenLanguages String[] @default([])

  /// Sprint DS7 — OPD token for the clinic queue. Auto-assigned
  /// server-side at session-create for the DOCTOR vertical (next integer
  /// among that doctor's sessions scheduled today); null for therapist
  /// rows + anything created before DS7. Drives the queue ordering on
  /// /app/clinic. See docs/DOCTOR_SCRIBE_V2_SPRINTS.md DS7.
  tokenNumber Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client              Client               @relation(fields: [clientId], references: [id])
  psychologist        Psychologist         @relation(fields: [psychologistId], references: [id])
  audioChunks         AudioChunk[]
  transcriptSegments  TranscriptSegment[]
  geminiCallLogs      GeminiCallLog[]
  noteDraft           NoteDraft?
  therapyNote         TherapyNote?
  clinicalReport      ClinicalReport?
  treatmentPlans      TreatmentPlan[]
  clientDiagnoses     ClientDiagnosis[]
  patientShares       PatientShare[]
  instrumentResponses InstrumentResponse[]
  safetyPlans         SafetyPlan[]
  // Doctor vertical — Sprint DV5. Drafted/confirmed Rx + clinical orders.
  medicationOrders    MedicationOrder[]
  clinicalOrders      ClinicalOrder[]
  // Doctor vertical — Sprint DV6. Differential diagnosis (reasoning copilot).
  differential        Differential?
  // Doctor vertical — Sprint DV7. Chronic-disease readings captured here.
  clinicalReadings    ClinicalReading[]
  // Sprint 73 — problems this session worked on (session↔problem tags).
  problemLinks        SessionProblemLink[]

  @@index([clientId, status])
  @@index([psychologistId, scheduledAt])
  @@index([psychologistId, status, scheduledAt])
  // Sprint DS7 — the clinic-queue read: today's sessions for a doctor,
  // ordered by token.
  @@index([psychologistId, scheduledAt, tokenNumber])
  @@map("sessions")
}

// ============================================================================
// AudioChunk — one row per uploaded chunk during a recording.
// Body lives in S3/MinIO under s3Key; this row is metadata only.
// Sprint 2 PR 2.
// ============================================================================

model AudioChunk {
  id         String @id @default(cuid())
  sessionId  String
  chunkIndex Int
  mimeType   String
  sampleRate Int
  sizeBytes  Int
  durationMs Int
  s3Key      String @default("")
  // Inline storage for PCM bytes. Used when the upload bypasses external
  // object storage (Sprint 2 fallback after @vercel/blob/client.upload()
  // hung silently in production). orchestrator.fetchAudio prefers
  // `bytes` when non-null; falls back to s3Key fetch for legacy rows.
  bytes      Bytes?

  uploadedAt DateTime @default(now())

  session Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  segment TranscriptSegment?

  @@unique([sessionId, chunkIndex])
  @@index([sessionId, uploadedAt])
  @@map("audio_chunks")
}

// ============================================================================
// TranscriptSegment — Sprint 57 transcribe-on-arrival.
// One row per AudioChunk holds the Pass 1 output for that 30s window so the
// orchestrator can assemble a finished transcript at "End session" instead of
// running Pass 1 on the whole session at once. Lifecycle:
//   PENDING      — row exists, transcription not started
//   TRANSCRIBING — in flight (claimed by an upload-route after() or a backstop)
//   COMPLETED    — transcript + per-window speakerSegments persisted
//   FAILED       — Gemini errored; the backstop at End retries
// ============================================================================

model TranscriptSegment {
  id           String                  @id @default(cuid())
  sessionId    String
  audioChunkId String                  @unique
  chunkIndex   Int
  status       TranscriptSegmentStatus @default(PENDING)

  // Pass 1 output for THIS window only. timestamps in speakerSegments /
  // affectFeatures are RELATIVE to the start of this chunk; the orchestrator
  // offsets them by the cumulative duration of prior chunks at assembly.
  transcript        String?  @db.Text
  speakerSegments   Json?
  affectFeatures    Json?
  detectedLanguages String[] @default([])

  model     String?
  region    String?
  costInr   Decimal @default(0) @db.Decimal(10, 4)
  latencyMs Int     @default(0)

  attempts     Int     @default(0)
  errorMessage String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  session    Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  audioChunk AudioChunk @relation(fields: [audioChunkId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId, status])
  @@map("transcript_segments")
}

enum TranscriptSegmentStatus {
  PENDING
  TRANSCRIBING
  COMPLETED
  FAILED
}

// ============================================================================
// Gemini call log — one row per Gemini API call. Persisted by packages/llm
// so the worker (Sprint 2 PR 4) and cost circuit breaker (PR 5) can roll up
// usage per session and per therapist. PRD Part 2 requires a `region` field.
// Sprint 2 PR 3.
// ============================================================================

/// Sprint 52 — Case Consult status, mirrors PreSessionBriefStatus.
enum CaseConsultStatus {
  PENDING
  COMPLETED
  FAILED
}

/// Sprint 53 — subscription plan tier. FREE_TRIAL is the default for
/// every new psychologist. SOLO_* are the legacy Sprint 53 plans, kept
/// for grandfathered payers (not offered to new buyers). Sprint 56 adds
/// the Trainee/Starter/Pro/Premium ladder (tier × interval). Per-plan
/// facts (price, period, cap) live in PLAN_CATALOG in
/// packages/contracts/src/billing.ts — this enum is just the identity.
enum BillingPlan {
  FREE_TRIAL
  SOLO_MONTHLY
  SOLO_ANNUAL
  TRAINEE_MONTHLY
  STARTER_MONTHLY
  STARTER_ANNUAL
  PRO_MONTHLY
  PRO_QUARTERLY
  PRO_ANNUAL
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

/// Sprint 53 — Razorpay payment lifecycle. CREATED on order, PAID
/// when the webhook confirms capture, FAILED on webhook failure.
enum BillingPaymentStatus {
  CREATED
  PAID
  FAILED
}

/// Sprint 53 — per-psychologist billing state. Sits beside the
/// Psychologist row (1:1) so the trial cap, plan, and paid-through
/// date are queryable in a single round-trip from any enforcement
/// site (session-create, sidebar usage, plan page).
model BillingAccount {
  id             String @id @default(cuid())
  psychologistId String @unique

  plan            BillingPlan @default(FREE_TRIAL)
  /// Number of sessions the trial allows; deliberately overridable
  /// so we can extend trial for friendly pilots without code change.
  trialSessionCap Int         @default(10)
  /// Paid-through date — null until the first PAID webhook lands.
  /// On every renewal the date extends from max(now, current value).
  paidThroughAt   DateTime?

  /// Sprint 56 (Lever 4 #4) — self-serve lifecycle.
  status              BillingAccountStatus @default(ACTIVE)
  /// Banked days when PAUSED. On pause we clear paidThroughAt and stash
  /// the remaining days here; resume restores paidThroughAt = now + this.
  pausedRemainingDays Int?
  /// Set when the therapist cancels. Access continues until paidThroughAt
  /// lapses, but renewal reminders + dunning go quiet.
  canceledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments BillingPayment[]

  @@index([psychologistId])
  @@map("billing_accounts")
}

/// Sprint 56 (Lever 4 #4) — self-serve plan lifecycle.
enum BillingAccountStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

/// Sprint 53 — one row per Razorpay order. CREATED when we open the
/// checkout, flipped to PAID by the webhook (idempotent), FAILED on
/// payment.failed. periodStart/End record the period the payment
/// covered — convenient for receipts later.
model BillingPayment {
  id               String @id @default(cuid())
  psychologistId   String
  billingAccountId String

  razorpayOrderId   String  @unique
  razorpayPaymentId String?

  plan        BillingPlan
  amountInr   Int
  status      BillingPaymentStatus @default(CREATED)
  periodStart DateTime?
  periodEnd   DateTime?
  /// Verbatim webhook event payload for audit / debugging.
  rawEvent    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)

  @@index([psychologistId, createdAt])
  @@map("billing_payments")
}

/// Sprint 56 (Lever 3b) — one referral code per therapist (their own
/// share link). Created lazily the first time they open the referral
/// card.
model ReferralCode {
  id             String   @id @default(cuid())
  psychologistId String   @unique
  code           String   @unique
  createdAt      DateTime @default(now())

  @@map("referral_codes")
}

/// Sprint 56 (Lever 3b) — one row per successful referred signup. The
/// referred therapist gets a free month immediately; the referrer's
/// reward is granted only when the referred CONVERTS (first PAID
/// payment), gated by rewardGrantedAt to prevent abuse + double-pay.
model ReferralRedemption {
  id                     String    @id @default(cuid())
  code                   String
  referrerPsychologistId String
  /// A given therapist can be referred at most once (unique).
  referredPsychologistId String    @unique
  /// Set when the referrer payout fires (referred's first PAID).
  rewardGrantedAt        DateTime?
  createdAt              DateTime  @default(now())

  @@index([referrerPsychologistId])
  @@index([code])
  @@map("referral_redemptions")
}

enum GeminiPass {
  PASS_1_TRANSCRIBE_AND_ANALYSE
  PASS_2_NOTE_GENERATION
  PASS_3_CLINICAL_ANALYSIS // Sprint 13 — Clinical Co-Pilot Pivot
  PASS_3_MISSED_THEMES
  PASS_4_THERAPY_SCRIPT // Sprint 14 — Therapy Script Pass
  PASS_5_PRE_SESSION_BRIEF // Sprint 17 — Pre-Session Brief
  PASS_6_CASE_BRIEFING // Sprint 22 — per-client case briefing synthesis
  PASS_7_CONCEPTUAL_MAP // Sprint 24 — Klarify-style per-client thematic graph
  PASS_8_CASE_CONSULT // Sprint 52 — second-opinion artefact for stuck cases
  PASS_9_DIFFERENTIAL // Sprint DV6 — doctor differential diagnosis
  PASS_10_FINDINGS // Sprint DS1 — live findings extractor (reasoning substrate)
  PASS_11_REASONING // Sprint DS2 — combined live reasoning (differential + ask-next)
  PASS_12_THERAPY_REASONING // Sprint TS5 — live therapy copilot (risk + ask-next + threads)
  ASSISTANT_CHAT // AUD1 — practice-assistant chat turns (metered + rate-limited)
  PASS_13_CARE_REPORT // Sprint AC4 — Cureocity Care kind-branched session report
  LIVE_CARE_SESSION // Sprint AC3 — Cureocity Care live voice session (Gemini Live)
}

enum GeminiCallStatus {
  SUCCESS
  ERROR
  TIMEOUT
  CIRCUIT_OPEN
}

model GeminiCallLog {
  id             String  @id @default(cuid())
  sessionId      String?
  /// AUD1 — tenant attribution for calls with no session (e.g. the practice
  /// assistant chat), so they count toward the monthly cost circuit and can
  /// be rate-limited per therapist. No FK — a plain indexed column.
  psychologistId String?

  pass          GeminiPass
  model         String
  region        String
  promptVersion String

  inputTokens  Int
  outputTokens Int
  costInr      Decimal @db.Decimal(10, 4)
  latencyMs    Int

  status       GeminiCallStatus
  errorMessage String?

  createdAt DateTime @default(now())

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([createdAt])
  @@index([status, createdAt])
  @@map("gemini_call_logs")
}

// ============================================================================
// NoteDraft — server-side row tracking one note-generation pipeline run.
// One per Session (unique). Populated by the note-generation worker
// in scribe-service. Sprint 2 PR 4.
// ============================================================================

enum NoteDraftStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NoteRiskSeverity {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model NoteDraft {
  id        String          @id @default(cuid())
  sessionId String          @unique
  status    NoteDraftStatus @default(PENDING)

  // Pass 1 outputs
  /// V1 plaintext column — retained during the encryption rollout window.
  /// Sprint 10 hardens cutover. Gap G10.
  transcript          String? @db.Text
  /// Envelope-encrypted transcript per @cureocity/crypto.
  transcriptEncrypted String? @db.Text
  speakerSegments     Json?
  affectFeatures      Json?

  // Pass 2 output (validated TherapyNoteV1)
  content      Json?
  riskSeverity NoteRiskSeverity?

  /// Sprint DS5 — the signable Rx pad (RxPadV1) assembled from the live
  /// consult, stored alongside the note + signed together.
  rxPad Json?

  // Cost rollup across Pass 1 + Pass 2 (and any retries).
  totalCostInr Decimal @default(0) @db.Decimal(10, 4)

  errorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  therapyNote TherapyNote?

  @@index([status, createdAt])
  @@map("note_drafts")
}

// ============================================================================
// TherapyNote — clinician-signed final note. Created from a completed
// NoteDraft when the therapist signs (Sprint 7).
// ============================================================================

model TherapyNote {
  id        String @id @default(cuid())
  sessionId String @unique
  draftId   String @unique

  version String
  content Json

  // Sprint DS5-fu — the SIGNED prescription pad (RxPadV1, confirmed meds
  // only), derived from NoteDraft.rxPad at sign time so the signature
  // attests the Rx. Null for therapy notes + notes signed before DS5-fu.
  // The clean, patient-safe source for the Rx PDF + RX_PAD share.
  rxPad Json?

  signedAt DateTime
  signedBy String

  // Sprint 71 — a signed note can be UNLOCKED back into the editable
  // (completed-draft) state so the therapist can use the full template /
  // language / edit toolbar, then re-sign. `locked = true` is the normal
  // signed-and-final state; `false` means it's been re-opened for editing.
  locked Boolean @default(true)

  // Non-repudiation proof — WebAuthn assertion captured at sign time.
  // The challenge bound into the assertion is sha256Hex(payload); the
  // server re-computed that hash on receipt and compared. Stored so an
  // auditor can independently verify months later. (gap G6/G11, Sprint 7 PR 4)
  signCredentialId          String?
  signClientDataJsonB64u    String?
  signAuthenticatorDataB64u String?
  signSignatureB64u         String?
  signChallengeHashHex      String?

  createdAt DateTime @default(now())

  session Session    @relation(fields: [sessionId], references: [id])
  draft   NoteDraft  @relation(fields: [draftId], references: [id])
  edits   NoteEdit[]

  @@map("therapy_notes")
}

// ============================================================================
// NoteEdit — one row per field the clinician changed between draft.content
// and the signed note. Captures the editorial trail required for clinical
// audit / regulator review (gap G11). Sprint 7 PR 4.
// ============================================================================

enum NoteEditField {
  subjective
  objective
  assessment
  plan
  // Sprint 49 — intake-note field-level edits. SignNoteInput picks the
  // applicable subset by session.kind.
  presentingConcerns
  historyOfPresentingIllness
  pastPsychiatricHistory
  familyHistory
  socialHistory
  mentalStatusExam
  workingHypothesis
  immediatePlan
  // Sprint DV3 — medical encounter note signable string fields.
  chiefComplaint
  hpi
}

model NoteEdit {
  id            String @id @default(cuid())
  therapyNoteId String

  field  NoteEditField
  before String        @db.Text
  after  String        @db.Text

  createdAt DateTime @default(now())

  therapyNote TherapyNote @relation(fields: [therapyNoteId], references: [id], onDelete: Cascade)

  @@index([therapyNoteId, createdAt])
  @@map("note_edits")
}

// ============================================================================
// Doctor vertical — Sprint DV5. MedicationOrder + ClinicalOrder.
//
// The AI drafts these from the encounter (status DRAFT); the doctor
// confirms each one (CONFIRMED) or discards it (DISCARDED) — nothing is
// ever auto-prescribed. Keyed by sessionId, tenant-filtered by
// psychologistId. `content` holds the validated MedicationOrderV1 /
// ClinicalOrderV1 JSON. Distinct from the therapy-exercise prescription
// engine — this is the drug Rx. See docs/DOCTOR_VERTICAL.md §6.
// ============================================================================

enum OrderStatus {
  DRAFT
  CONFIRMED
  DISCARDED
}

model MedicationOrder {
  id             String      @id @default(cuid())
  sessionId      String
  psychologistId String
  status         OrderStatus @default(DRAFT)

  /// Validated MedicationOrderV1 (drug, dose, frequency, duration,
  /// interactionWarnings[] computed server-side at draft time).
  content Json

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([psychologistId])
  @@map("medication_orders")
}

model ClinicalOrder {
  id             String      @id @default(cuid())
  sessionId      String
  psychologistId String
  status         OrderStatus @default(DRAFT)

  /// Validated ClinicalOrderV1 (category, description, rationale).
  content Json

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([psychologistId])
  @@map("clinical_orders")
}

// ============================================================================
// Doctor vertical — Sprint DV6. Differential — the reasoning copilot's
// output for one encounter (the medical analogue of ClinicalReport). One
// row per session; `body` holds the validated DifferentialDiagnosisV1.
// Decision-support only — never auto-applied to the note. See
// docs/DOCTOR_VERTICAL.md §6, §7.
// ============================================================================

model Differential {
  id             String          @id @default(cuid())
  sessionId      String          @unique
  psychologistId String
  status         NoteDraftStatus @default(PENDING)

  /// Validated DifferentialDiagnosisV1 (candidates + coding nudges).
  body         Json?
  errorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([psychologistId])
  @@map("differentials")
}

// ============================================================================
// Doctor vertical — Sprint DV7. ClinicalReading — a single chronic-disease
// measurement (BP / HbA1c / FBS / LDL / weight) in a per-patient time
// series. Auto-captured from the medical note's vitals on note completion
// (source NOTE_VITALS) or logged manually (source MANUAL). The control /
// trend verdicts are computed deterministically by @cureocity/clinical.
// See docs/DOCTOR_VERTICAL.md §9.
// ============================================================================

enum ChronicMeasure {
  BP
  HBA1C
  FBS
  LDL
  WEIGHT
}

model ClinicalReading {
  id             String         @id @default(cuid())
  clientId       String
  psychologistId String
  sessionId      String?
  measure        ChronicMeasure

  /// Primary value (systolic for BP).
  value          Float
  /// Secondary value — diastolic for BP; null otherwise.
  valueSecondary Float?
  unit           String
  takenAt        DateTime
  /// 'NOTE_VITALS' (auto from the note) | 'MANUAL' (doctor-entered).
  source         String   @default("MANUAL")

  createdAt DateTime @default(now())

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([clientId, measure, takenAt])
  @@index([psychologistId])
  @@index([sessionId])
  @@map("clinical_readings")
}

// ============================================================================
// NoteTemplate — therapist-owned customizable note structures. Sprint 11.
// Each template owns an ordered list of sections; downstream the Pass 2
// system prompt is rewritten to ask the model to populate the named
// sections from the transcript.
// ============================================================================

model NoteTemplate {
  id             String @id @default(cuid())
  psychologistId String

  name        String
  description String? @db.Text

  /// Ordered list of { id, title, hint? } entries describing each
  /// section the template emits. Stored as JSON so the schema can
  /// evolve without migrations as section types grow (bullets,
  /// checklists, plain prose, etc.).
  sections Json @default("[]")

  /// Exactly one template per psychologist may carry isDefault=true;
  /// enforced at the application layer in apps/web/app/api/v1/templates.
  /// Default templates are the one new notes start from when the
  /// therapist hasn't picked another.
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  psychologist Psychologist @relation(fields: [psychologistId], references: [id])

  @@index([psychologistId, updatedAt])
  @@map("note_templates")
}

// ============================================================================
// ClinicalReport — Sprint 13 (Clinical Co-Pilot Pivot). One per Session.
// Pass 3 fills in `body` (a ClinicalReportV1 JSON object). The therapist
// then reviews each section in the Clinical Brief UI; per-section
// confirm state lives in `confirmations` JSONB. Confirmed diagnosis +
// plan replicate to ClientDiagnosis + TreatmentPlan respectively for
// cumulative cross-session view.
// ============================================================================

enum ClinicalReportStatus {
  PENDING
  COMPLETED
  FAILED
}

model ClinicalReport {
  id             String @id @default(cuid())
  sessionId      String @unique
  clientId       String
  psychologistId String

  status ClinicalReportStatus @default(PENDING)

  /// Pass 3 output validated against ClinicalReportV1Schema. Nullable
  /// until the orchestrator successfully writes the model output.
  body Json?

  /// Per-section confirmation state, shape:
  /// {
  ///   diagnosis|gaps|formulation|plan|therapies|crisis: {
  ///     status, confirmedAt, confirmedByPsychologistId, reason, edits
  ///   }
  /// }
  /// Defaults to every section PENDING; route handlers validate the
  /// payload against ClinicalSectionConfirmationsSchema.
  confirmations Json @default("{}")

  totalCostInr Decimal @default(0) @db.Decimal(10, 4)
  errorMessage String? @db.Text

  /// Sprint TSC-V2 — set when the therapist taps "Finish review" on the
  /// copilot decision board's wrap-up step. Marks the session's copilot
  /// review as complete; decisions stay revisable after (this is a
  /// checkpoint, not a lock).
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session         Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist    Psychologist      @relation(fields: [psychologistId], references: [id])
  clientDiagnoses ClientDiagnosis[]
  treatmentPlans  TreatmentPlan[]

  @@index([clientId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([status, createdAt])
  @@map("clinical_reports")
}

// ============================================================================
// ClientDiagnosis — cumulative per-client diagnosis record. One row per
// confirmed diagnosis decision (from the Clinical Brief tab). Older
// rows are kept (supersededAt set) when the therapist updates the
// diagnosis on a later session so the historical record is reviewable.
// ============================================================================

model ClientDiagnosis {
  id               String @id @default(cuid())
  clientId         String
  psychologistId   String
  sessionId        String
  clinicalReportId String

  /// ICD-11 code (e.g. "6B00", "6B01.0"). Kept English per WHO.
  icd11Code  String
  icd11Label String

  confidence Float

  /// Array of { quote, speaker, startMs } supporting quotes drawn from
  /// the source transcript. Schema enforced at route layer via
  /// ClinicalSupportingQuoteSchema[].
  supportingEvidence Json @default("[]")

  /// Exactly one isPrimary=true per client at a time across non-
  /// superseded rows; app layer enforces (route flips the previous
  /// primary's supersededAt on conflict).
  isPrimary Boolean @default(false)

  /// When the therapist confirmed this diagnosis (= source row's
  /// confirmedAt in the ClinicalReport.confirmations.diagnosis entry).
  confirmedAt               DateTime
  confirmedByPsychologistId String

  /// Set when a later confirmation supersedes this row.
  supersededAt DateTime?
  notes        String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist   Psychologist    @relation(fields: [psychologistId], references: [id])
  session        Session         @relation(fields: [sessionId], references: [id])
  clinicalReport ClinicalReport  @relation(fields: [clinicalReportId], references: [id])
  therapyScripts TherapyScript[]

  @@index([clientId, supersededAt])
  @@index([clientId, isPrimary, supersededAt])
  @@index([psychologistId, createdAt])
  @@map("client_diagnoses")
}

// ============================================================================
// TreatmentPlan — cumulative per-client plan. Versioned: every
// confirmed plan from a session's Clinical Brief bumps the version
// and supersedes the previously active row. The Treatment Library
// and pre-session brief (Sprint 17) read the active row.
// ============================================================================

model TreatmentPlan {
  id                     String @id @default(cuid())
  clientId               String
  psychologistId         String
  sourceSessionId        String
  sourceClinicalReportId String

  /// Auto-incrementing per client. Computed at insert by the route
  /// (MAX(version)+1 within client scope).
  version Int

  /// Validated against ClinicalTreatmentPlanSchema before write.
  body Json

  confirmedAt               DateTime
  confirmedByPsychologistId String

  /// When the therapist confirms a new plan, the previous active
  /// plan's supersededAt is set.
  supersededAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist   Psychologist    @relation(fields: [psychologistId], references: [id])
  session        Session         @relation(fields: [sourceSessionId], references: [id])
  clinicalReport ClinicalReport  @relation(fields: [sourceClinicalReportId], references: [id])
  therapyScripts TherapyScript[]

  goalProgress TreatmentGoalProgress[]

  @@unique([clientId, version])
  @@index([clientId, supersededAt])
  @@index([psychologistId, createdAt])
  @@map("treatment_plans")
}

// ============================================================================
// TreatmentGoalProgress — Sprint 20 Phase 3 follow-up.
// Per-goal achievement status, keyed by (treatmentPlanId, goalIndex)
// against the goals array inside TreatmentPlan.body. Kept as a side
// table (not inside the versioned plan JSON) so toggling status doesn't
// re-version the plan and historical plans keep their own progress.
// ============================================================================

enum TreatmentGoalStatus {
  NOT_STARTED
  IN_PROGRESS
  ACHIEVED
}

model TreatmentGoalProgress {
  id                      String              @id @default(cuid())
  treatmentPlanId         String
  goalIndex               Int
  status                  TreatmentGoalStatus @default(NOT_STARTED)
  updatedByPsychologistId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

  @@unique([treatmentPlanId, goalIndex])
  @@index([treatmentPlanId])
  @@map("treatment_goal_progress")
}

// ============================================================================
// TreatmentEpisode — Sprint 20 Phase 3.
// Groups a client's care from intake → discharge into an episode so the
// journey arc has a durable terminal state instead of a purely derived
// one. A new episode is ensured OPEN when a session is created and no
// OPEN episode exists; discharge closes it. A client who returns after
// discharge starts a fresh episode. psychologistId is a plain scalar
// (no relation) to keep the Psychologist model untouched.
// ============================================================================

enum TreatmentEpisodeStatus {
  OPEN
  DISCHARGED
  TRANSFERRED
}

model TreatmentEpisode {
  id             String                 @id @default(cuid())
  clientId       String
  psychologistId String
  status         TreatmentEpisodeStatus @default(OPEN)

  openedAt DateTime  @default(now())
  closedAt DateTime?

  /// Free-text reason captured on close (discharge / transfer).
  closeReason String?

  /// Optional clinician outcome note shown alongside the final report.
  outcomeNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, openedAt])
  @@index([clientId, status])
  @@map("treatment_episodes")
}

// ============================================================================
// AssessmentItem — Sprint 22 "running differential".
// A persisted, trackable diagnostic / assessment question. Generated
// from Pass 3 output (the brief's assessmentGaps + each candidate's
// gapsToFill), carried forward across sessions, and closed by the
// therapist (or auto-suggested closed when a later Pass 3 no longer
// lists it). The set of OPEN items IS the "what to ask next session"
// surface — the SCID-style running differential the product was
// regenerating + discarding every session.
// ============================================================================

enum AssessmentItemStatus {
  OPEN
  ADDRESSED
  CLOSED
}

enum AssessmentItemKind {
  DIAGNOSTIC_CRITERION
  ASSESSMENT_GAP
  INSTRUMENT
  SAFETY
}

model AssessmentItem {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  /// Groups items within one episode of care (nullable for legacy).
  episodeId String?

  kind      AssessmentItemKind
  question  String
  rationale String

  /// Optional ICD-11 code of the candidate this item tests.
  icd11Code String?

  status AssessmentItemStatus @default(OPEN)

  /// Pass 3 session the item originated from; session it was closed in.
  sourceSessionId    String?
  addressedSessionId String?

  /// Therapist's one-line finding when the item is closed.
  resolutionNote String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@map("assessment_items")
}

// ============================================================================
// TherapyScript — Sprint 14 cache row for Pass 4 output. Keyed by
// (clientId, cacheKey) where cacheKey is a SHA-256 hash of the
// normalised input tuple (therapyName, language, primaryDiagnosis,
// active treatment plan, last-session summary). A re-view under the
// same context returns the cached script — no second Vertex bill.
// ============================================================================

// ============================================================================
// PatientShare — Sprint 15.
// One row per (artefact, channel) Send-to-patient action. The
// snapshot column locks in the artefact body at share time so the
// patient always sees what was sent, even if the source row is
// later edited or deleted. The shareToken opens a public read-only
// portal at /p/<token>.
// ============================================================================

enum PatientShareArtefactType {
  SIGNED_NOTE
  REFLECTION_QUESTIONS
  THERAPY_SCRIPT
  TREATMENT_PLAN
  PROGRESS_REPORT
  INSTRUMENT_CHECKIN // Sprint 47 — interactive self-serve check-in
  SIGNED_INTAKE_NOTE // Sprint 49 — intake-note counterpart to SIGNED_NOTE
  AFTER_VISIT_SUMMARY // Sprint DV3 — doctor after-visit summary
  CHRONIC_PROGRESS_REPORT // Sprint DV7 — doctor chronic-disease progress report
  RX_PAD // Sprint DS5-fu — doctor prescription pad (signed Rx, confirmed meds)
}

/// Sprint 47 — how an InstrumentResponse was administered.
enum InstrumentAdministrationMode {
  CLINICIAN
  SELF
}

enum PatientShareChannel {
  WHATSAPP
  EMAIL
  PORTAL_LINK
}

enum PatientShareStatus {
  PENDING
  SENT
  OPENED
  TRANSIENT_FAILURE
  PERMANENT_FAILURE
  REVOKED
}

model PatientShare {
  id             String  @id @default(cuid())
  clientId       String
  psychologistId String
  sessionId      String?

  artefactType PatientShareArtefactType
  artefactId   String

  channel PatientShareChannel
  status  PatientShareStatus  @default(PENDING)

  /// 22-char base64url. Unique across all shares; the portal route
  /// looks up by this directly. Public — entropy is the only auth.
  shareToken String @unique

  /// Language the portal renders in (ISO 639-1).
  language String @default("en")

  /// Discriminated-union snapshot of the artefact body. Validated
  /// at the route layer against PatientShareSnapshotSchema.
  snapshot Json

  /// Short title used in the channel message + portal page.
  subject String

  /// Contact at send time — phone for WhatsApp, email for email.
  /// PORTAL_LINK rows have null toContact.
  toContact String?

  /// Provider message id, e.g. "wati:abc123", "sendgrid:xyz789".
  providerMessageId String?

  /// Set when the channel returns a failure outcome.
  errorCode   String?
  errorDetail String? @db.Text

  /// When the channel adapter returned a non-error result.
  sentAt DateTime?

  /// First-opened timestamp on the portal. Repeat views are tracked
  /// in the audit log, not here.
  openedAt DateTime?

  /// SHARE-1 — set when the therapist revokes the link (status → REVOKED).
  /// From this point the portal refuses to render the artefact.
  revokedAt DateTime?

  /// Token expiry. Defaults to 30 days from creation in the route.
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])
  session      Session?     @relation(fields: [sessionId], references: [id])

  @@index([clientId, createdAt])
  @@index([psychologistId, createdAt])
  @@index([status, createdAt])
  @@index([sessionId])
  @@map("patient_shares")
}

model TherapyScript {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  therapyName String
  language    String

  /// 64-char hex SHA-256 of the normalised input tuple.
  cacheKey String

  /// Validated against TherapyScriptV1Schema before write.
  body Json

  /// Optional grounding — the TreatmentPlan + primary ClientDiagnosis
  /// the script was generated against. Nullable because both can be
  /// absent at script-generation time (e.g. browse-only mode).
  sourceTreatmentPlanId    String?
  sourcePrimaryDiagnosisId String?

  totalCostInr Decimal @default(0) @db.Decimal(10, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist     @relation(fields: [psychologistId], references: [id])
  plan         TreatmentPlan?   @relation(fields: [sourceTreatmentPlanId], references: [id])
  diagnosis    ClientDiagnosis? @relation(fields: [sourcePrimaryDiagnosisId], references: [id])

  @@unique([clientId, cacheKey])
  @@index([clientId, therapyName])
  @@index([psychologistId, createdAt])
  @@map("therapy_scripts")
}

// ============================================================================
// PreSessionBrief — Sprint 17. Pass 5 output cached per
// (clientId, lastSessionId, language). The therapist opens the
// client and sees what to focus on today, grounded in the most
// recent confirmed clinical record + therapy script + homework.
// Cache invalidates whenever a new session lands.
// ============================================================================

enum PreSessionBriefStatus {
  PENDING
  COMPLETED
  FAILED
}

model PreSessionBrief {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  /// Which session the brief is grounded against (the most recent
  /// COMPLETED session at generation time). Null for "first session"
  /// briefs.
  lastSessionId String?

  language String                @default("en")
  status   PreSessionBriefStatus @default(PENDING)

  /// Validated against PreSessionBriefV1Schema before write.
  body Json?

  totalCostInr Decimal @default(0) @db.Decimal(10, 4)
  errorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])

  @@index([clientId, createdAt])
  @@index([psychologistId, createdAt])
  @@map("pre_session_briefs")
}

// ============================================================================
// CaseConsult — Sprint 52. Pass 8 output. A structured second opinion
// the therapist generates when they're stuck on a case. Cached per
// (clientId, lastSessionId) and invalidated by the next completed
// session. Never patient-shareable.
// ============================================================================

model CaseConsult {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  /// Most recent COMPLETED session at generation time; null for
  /// brand-new clients (no completed sessions yet).
  lastSessionId String?

  status CaseConsultStatus @default(PENDING)

  /// Validated against CaseConsultV1Schema before write.
  body Json?

  totalCostInr Decimal @default(0) @db.Decimal(10, 4)
  errorMessage String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([psychologistId, createdAt])
  @@map("case_consults")
}

// ============================================================================
// ClientConceptualMap — Sprint 24. Pass 7 output. Per-client cumulative
// graph of values / affirmations / challenges / patterns / beliefs that
// surfaced across the client's sessions, with verbatim supporting quotes
// + reflection prompts per node. Versioned via `supersededAt` (each
// refresh creates a new row and sets the previous row's supersededAt).
// ============================================================================

model ClientConceptualMap {
  id                String    @id @default(cuid())
  clientId          String
  psychologistId    String
  /// ConceptualMapV1 — see packages/contracts/src/conceptual-map.ts.
  body              Json
  /// Session IDs the prompt actually saw — for the audit trail.
  basedOnSessionIds Json
  generatedAt       DateTime  @default(now())
  /// Set when a newer map is generated. Null on the live row.
  supersededAt      DateTime?
  /// "llm" today. "fallback-empty" reserved for future deterministic placeholder.
  source            String    @default("llm")

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([clientId, supersededAt])
  @@index([psychologistId, generatedAt])
  @@map("client_conceptual_maps")
}

// ============================================================================
// InstrumentResponse — Sprint 17. A single administration of a
// scored clinical instrument (PHQ-9, GAD-7, ...). One row per
// administration; trends are queryable per (clientId, instrumentKey).
//
// `responses` JSONB stores the item-id → integer-value map; `score`
// and `severity` are denormalised for fast querying + display in the
// pre-session brief.
// ============================================================================

model InstrumentResponse {
  id             String  @id @default(cuid())
  clientId       String
  psychologistId String
  sessionId      String?

  /// Stable identifier from packages/clinical/src/instruments,
  /// e.g. "PHQ9" | "GAD7" | "WHODAS2_12".
  instrumentKey String

  /// ISO 639-1 — language the items were presented in. Defaults to
  /// "en"; non-English uses only ship once validated translations
  /// are vetted by a clinician.
  language String @default("en")

  /// Item-id → integer answer map (1-based, matching the catalog).
  responses Json

  score    Int
  /// Severity band label as defined by the instrument
  /// (e.g. "minimal", "mild", "moderate", "severe").
  severity String

  /// CLIN-1 — the instrument's own safety bit (e.g. PHQ-9 item 9
  /// endorsed). Persisted on the record, not just the audit log, so a
  /// self-check-in suicidality endorsement is queryable — it feeds the
  /// crisis pathway (Prepare panel + pre-session brief) and the
  /// immediate therapist alert instead of being lost in a trend.
  riskFlagged Boolean @default(false)

  /// When the instrument was administered. May predate createdAt for
  /// backfilled rows.
  administeredAt               DateTime
  administeredByPsychologistId String

  /// Sprint 47 — CLINICIAN (in-session runner) vs SELF (remote portal
  /// check-in the client completed). Defaults to CLINICIAN so existing
  /// rows + the in-session route keep their meaning without a backfill.
  administrationMode InstrumentAdministrationMode @default(CLINICIAN)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])
  session      Session?     @relation(fields: [sessionId], references: [id])

  @@index([clientId, instrumentKey, administeredAt])
  @@index([psychologistId, createdAt])
  @@map("instrument_responses")
}

// ============================================================================
// SafetyPlan — Sprint 17. Stanley & Brown 5-step crisis safety plan
// created when a Crisis section is confirmed at high/critical
// severity. Cumulative per client (the most recent supersedes
// earlier ones; old rows are kept with supersededAt set so the
// audit trail is intact).
// ============================================================================

model SafetyPlan {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  /// Optional — the session where the crisis surfaced.
  sourceSessionId String?

  language String @default("en")

  /// Validated against SafetyPlanV1Schema before write.
  body Json

  /// When the therapist confirmed this plan.
  confirmedAt               DateTime
  confirmedByPsychologistId String

  /// Set when a later plan supersedes this one.
  supersededAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])
  session      Session?     @relation(fields: [sourceSessionId], references: [id])

  @@index([clientId, supersededAt])
  @@index([psychologistId, createdAt])
  @@map("safety_plans")
}

// ============================================================================
// ExerciseAssignment / MoodLog / JournalEntry — continuity-service tables.
// Sprint 5 PR 1.
// ============================================================================

enum ExerciseAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  EXPIRED
}

/// Sprint 51 — provenance for an ExerciseAssignment row.
/// CATALOG = therapist hand-picked from the @cureocity/clinical catalog.
/// THERAPY_SCRIPT = auto-created when sharing a therapy script so the
/// script's `homework` field persists as a trackable assignment and
/// the patient's "Mark as done" on the portal feeds the pre-session
/// brief deterministically.
enum ExerciseAssignmentSource {
  CATALOG
  THERAPY_SCRIPT
}

model ExerciseAssignment {
  id             String @id @default(cuid())
  clientId       String
  psychologistId String

  // Catalog id like 'cbt_thought_record_5col' or 'emdr_safe_place_installation'.
  // Validated against @cureocity/clinical at the service layer.
  // Sprint 51 — nullable so script-sourced rows can carry free-text
  // homework (the script's `homework.description`, which doesn't match
  // the catalog regex) without needing a fake catalog id.
  exerciseId String?

  // Sprint 51 — provenance + free-text description for non-catalog rows.
  source                ExerciseAssignmentSource @default(CATALOG)
  customDescription     String?                  @db.Text
  sourceTherapyScriptId String?

  assignedAt DateTime  @default(now())
  dueAt      DateTime?

  status      ExerciseAssignmentStatus @default(PENDING)
  completedAt DateTime?
  // Structured per the exercise's responseSchema.
  response    Json?

  // Free-text note from therapist when assigning.
  therapistNote String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])

  @@index([clientId, status])
  @@index([psychologistId, assignedAt])
  @@index([clientId, exerciseId, assignedAt])
  @@map("exercise_assignments")
}

model MoodLog {
  id         String   @id @default(cuid())
  clientId   String
  // 0..10 valence-style mood rating.
  rating     Int
  notes      String?  @db.Text
  recordedAt DateTime

  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, recordedAt])
  @@map("mood_logs")
}

model JournalEntry {
  id               String   @id @default(cuid())
  clientId         String
  /// V1 plaintext column — retained during the encryption rollout window.
  /// Continuity-service writes BOTH `content` and `contentEncrypted` when a
  /// TenantDataKey is available; reads prefer `contentEncrypted` and fall
  /// back to `content`. Sprint 10 hardening drops this column. Gap G10.
  content          String   @db.Text
  /// Envelope-encrypted form per @cureocity/crypto. Populated from
  /// Sprint 9 PR 3 onward.
  contentEncrypted String?  @db.Text
  // Optional 0..10 mood tag.
  mood             Int?
  recordedAt       DateTime

  // When true, the entry is visible in the therapist briefing; when false
  // (default), it stays private to the client. Added Sprint 8 PR 2 for
  // the journal share/private toggle the patient PWA exposes.
  sharedWithTherapist Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, recordedAt])
  @@map("journal_entries")
}

// ============================================================================
// ModalityState — one active workflow per client. Tracks current phase in the
// modality state machine (CBT 5-phase, EMDR 8-phase, ...) plus opaque
// modality-specific state validated by packages/clinical. Sprint 3 PR 1.
// ============================================================================

model ModalityState {
  id             String @id @default(cuid())
  clientId       String @unique
  psychologistId String

  modality     SessionModality
  // Phase string is validated against the modality's allowed phases by
  // @cureocity/clinical at the service layer — not enforced at DB level
  // because different modalities have different phase sets.
  currentPhase String

  // Modality-specific state (e.g. CBT thought-record corpus, EMDR target list).
  state Json @default("{}")

  // Goals defined at intake. Shape:
  // [{ id, description, targetSessionCount?, achieved, achievedAt?, evidence? }]
  goals Json @default("[]")

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client               @relation(fields: [clientId], references: [id])
  psychologist Psychologist         @relation(fields: [psychologistId], references: [id])
  transitions  ModalityTransition[]
  emdrTargets  EmdrTarget[]

  @@index([psychologistId, modality])
  @@map("modality_states")
}

enum ModalityTransitionTrigger {
  PSYCHOLOGIST_MANUAL
  SYSTEM_SUGGESTION_ACCEPTED
  SYSTEM_AUTO
}

model ModalityTransition {
  id        String @id @default(cuid())
  stateId   String
  fromPhase String
  toPhase   String

  trigger        ModalityTransitionTrigger
  reason         String
  psychologistId String?
  // Evidence at transition time — adherence stats, note phaseHints, etc.
  evidence       Json?

  occurredAt DateTime @default(now())

  state ModalityState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([stateId, occurredAt])
  @@map("modality_transitions")
}

// ============================================================================
// EmdrTarget — one target memory inside an EMDR workflow. Sprint 4 PR 2.
// Stored separately from ModalityState.state because SUDS/VOC trend over
// time is queryable and indexable per-target.
// ============================================================================

enum EmdrTargetStatus {
  identified
  assessed
  in_desensitization
  desensitized
  installed
  body_scan_clear
  closed
}

model EmdrTarget {
  id      String @id @default(cuid())
  stateId String

  label             String
  image             String @db.Text
  negativeCognition String @db.Text
  positiveCognition String @db.Text

  vocStart    Int
  vocCurrent  Int?
  sudsStart   Int
  sudsCurrent Int?

  emotion      String
  bodyLocation String

  status             EmdrTargetStatus @default(identified)
  bilateralSetsTotal Int              @default(0)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  state ModalityState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@index([stateId, status])
  @@map("emdr_targets")
}

// ============================================================================
// Letter — Sprint 66. Therapist-authored letters (referral to a
// psychiatrist/GP, attendance, fitness-to-work/study, general support).
// Body is composed deterministically from a template + case data, edited
// by the therapist, then rendered to a credential-stamped PDF. Scalar
// owner FKs (no relations) keep the migration self-contained.
// ============================================================================

model Letter {
  id             String     @id @default(cuid())
  clientId       String
  psychologistId String
  kind           LetterKind

  /// Addressee line, e.g. "Dr. A. Sharma" or "To whom it may concern".
  recipient String
  /// Short subject / re-line.
  subject   String
  /// The letter body — paragraphs separated by blank lines.
  body      String @db.Text

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
  @@index([psychologistId, createdAt])
  @@map("letters")
}

enum LetterKind {
  REFERRAL
  ATTENDANCE
  FITNESS
  SUPPORT
}

// ============================================================================
// ProblemListItem — Sprint 67c. A maintained, editable per-client problem
// list (seeded from the Case Briefing, then therapist-owned). A stable
// clinical artefact, distinct from the auto-synthesised briefing. Scalar
// owner FKs keep the migration self-contained.
// ============================================================================

model ProblemListItem {
  id             String        @id @default(cuid())
  clientId       String
  psychologistId String
  title          String
  detail         String?       @db.Text
  status         ProblemStatus @default(ACTIVE)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  // Sprint 73 — sessions that worked on this problem (thread across the case).
  sessionLinks SessionProblemLink[]

  @@index([clientId, status])
  // The client page lists problems ordered by createdAt desc; without this
  // the (clientId, status) index can't serve the sort.
  @@index([clientId, createdAt])
  @@map("problem_list_items")
}

// ============================================================================
// SessionProblemLink — Sprint 73. Join table tagging which problem-list
// items a session worked on. Lets the therapist thread a single problem
// across the whole case (which sessions advanced it) and see, on any note,
// what was addressed that session. Tenant column carried for query filters.
// ============================================================================

model SessionProblemLink {
  id                String   @id @default(cuid())
  sessionId         String
  problemListItemId String
  psychologistId    String
  createdAt         DateTime @default(now())

  session Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problem ProblemListItem @relation(fields: [problemListItemId], references: [id], onDelete: Cascade)

  @@unique([sessionId, problemListItemId])
  @@index([problemListItemId])
  @@index([sessionId])
  @@map("session_problem_links")
}

enum ProblemStatus {
  ACTIVE
  RESOLVED
}

// ============================================================================
// NoteReview — Sprint 68. A record that a signed note was reviewed in
// supervision (reviewer name + optional feedback + date). Captures the
// supervision/medico-legal artefact without a full multi-account
// supervisor-relationship system. Scalar owner FKs keep it self-contained.
// ============================================================================

model NoteReview {
  id             String   @id @default(cuid())
  sessionId      String
  therapyNoteId  String
  psychologistId String
  reviewerName   String
  reviewerNote   String?  @db.Text
  reviewedAt     DateTime

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([psychologistId, createdAt])
  @@map("note_reviews")
}

/// Sprint DS0 — per-consult token / cost / latency meter for the doctor
/// live copilot. The streaming gateway can't touch the DB, so the browser
/// relays the gateway's meter summary to POST /sessions/:id/live-metric,
/// which writes one row per consult. Telemetry only (scalar keys, no FK) —
/// it holds the unit economics honest: ≤ ₹2 / consult, transcript p95 ≤ 2s.
model LiveConsultMetric {
  id             String @id @default(cuid())
  sessionId      String
  psychologistId String

  /// 'mock' | 'vertex' — which backend produced these numbers.
  backend String

  windows      Int
  pass1Calls   Int
  pass2Calls   Int
  inputTokens  Int
  outputTokens Int
  costInr      Decimal @db.Decimal(10, 4)

  transcriptP50Ms         Int
  transcriptP95Ms         Int
  /// DOC-9 — honest speech→transcript latency (window-wait included).
  speechToTranscriptP50Ms Int @default(0)
  speechToTranscriptP95Ms Int @default(0)
  noteP50Ms               Int
  noteP95Ms               Int
  elapsedMs               Int

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([psychologistId, createdAt])
  @@map("live_consult_metrics")
}

// ============================================================================
// AuditLog — append-only. Polymorphic target via (targetType, targetId).
// Every state-changing endpoint writes one row. Read access surface added in
// Sprint 9 with admin role (gap G9).
// ============================================================================

enum AuditAction {
  // Psychologist
  PSYCHOLOGIST_REGISTERED
  PSYCHOLOGIST_UPDATED

  // Client
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_VIEWED
  CLIENT_BRIEFING_VIEWED
  CLIENT_SOFT_DELETED

  // Consent
  CONSENT_GRANTED
  CONSENT_WITHDRAWN
  CONSENT_EXPIRED

  // Sessions (scribe-service, Sprint 2)
  SESSION_CREATED
  SESSION_CONSENT_RECORDED
  SESSION_STARTED
  SESSION_ENDED
  SESSION_CANCELLED
  // Sprint 45 — Today screen status transitions.
  SESSION_NO_SHOW
  SESSION_RESCHEDULED

  // Audio + notes (scribe-service, Sprint 2)
  AUDIO_CHUNK_UPLOADED
  // Sprint 57 — transcribe-on-arrival lifecycle.
  TRANSCRIPT_SEGMENT_TRANSCRIBED
  TRANSCRIPT_SEGMENT_FAILED
  NOTE_DRAFT_CREATED
  NOTE_DRAFT_VIEWED
  NOTE_SIGNED
  // Sprint 71 — a signed note re-opened for editing.
  NOTE_UNLOCKED

  // Cost + risk (scribe-service, Sprint 2)
