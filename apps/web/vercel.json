{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm exec prisma generate && bash scripts/vercel-db-setup.sh && pnpm -r --filter \"@cureocity/web...\" build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/v1/cron/audio-retention",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/billing-reminders",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/v1/cron/reclaim-stuck",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/v1/cron/unsigned-digest",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/v1/cron/care-session-sweeper",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/v1/cron/care-nudges",
      "schedule": "0 * * * *"
    }
  ],
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
