{
  "name": "therapist-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/therapist-web",
  "projectType": "application",
  "tags": ["scope:frontend", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "command": "next build",
        "cwd": "apps/therapist-web"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "command": "tsc --noEmit", "cwd": "apps/therapist-web" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "eslint app components lib --max-warnings 0 --no-error-on-unmatched-pattern",
        "cwd": "apps/therapist-web"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "echo 'No web tests yet (component + e2e in Sprint 7/9)'",
        "cwd": "apps/therapist-web"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "next dev --port 3100", "cwd": "apps/therapist-web" }
    }
  }
}
