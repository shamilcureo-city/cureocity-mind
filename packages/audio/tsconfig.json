{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "incremental": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
