{
  "name": "llm",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/llm/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:library"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": { "command": "tsc -p tsconfig.build.json", "cwd": "packages/llm" }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "command": "tsc --noEmit", "cwd": "packages/llm" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "eslint src --max-warnings 0 --no-error-on-unmatched-pattern",
        "cwd": "packages/llm"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "command": "vitest run", "cwd": "packages/llm" }
    }
  }
}
