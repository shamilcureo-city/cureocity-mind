# =============================================================================
# Cureocity Mind — environment variables.
#
# Copy to `.env.local` for local development; in production these live in
# Vercel project settings. Vars marked `(public)` are exposed to the browser
# via the NEXT_PUBLIC_ prefix; everything else is server-only.
#
# Quick start (mock backend, no GCP creds needed):
#   1. Set DATABASE_URL to your Neon dev branch or local Postgres
#   2. Leave LLM_BACKEND=mock (default)
#   3. Don't set the FIREBASE_* keys — auth bypass auto-engages and the
#      seeded "dev-firebase-uid-priya" fixture answers every request.
#   4. Run `pnpm --filter @cureocity/web dev`.
#
# Comprehensive reference: see § "Environment variables" in docs/SETUP.md
# and CLAUDE.md § 9 for the full set across all 18 sprints.
# =============================================================================

# -----------------------------------------------------------------------------
# Required for production. The site will not work correctly without these.
# -----------------------------------------------------------------------------

# Database — Neon in production, local Postgres in dev. The Vercel-Neon
# integration auto-populates the three POSTGRES_* aliases below; the app
# (apps/web/lib/prisma.ts) reads whichever is set first.
DATABASE_URL=postgresql://cureocity:cureocity@localhost:5432/cureocity_mind
DATABASE_URL_UNPOOLED=postgresql://cureocity:cureocity@localhost:5432/cureocity_mind
# POSTGRES_PRISMA_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# LLM backend selection. `mock` = deterministic stubs end-to-end (no GCP needed).
# `vertex` = real Gemini 1.5/2.5 via Vertex AI; requires VERTEX_* + GCP creds below.
LLM_BACKEND=mock
# Exposed to the browser so the dev-mode "Mock backend" banner can render.
NEXT_PUBLIC_LLM_BACKEND=mock

# Vercel Blob — required for audio chunk persistence as soon as you record.
# Generate from the Vercel Blob dashboard.
# BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# Vertex AI / Gemini — required only when LLM_BACKEND=vertex.
# -----------------------------------------------------------------------------

# Project + creds.
# VERTEX_PROJECT_ID=
# Paste the full service-account JSON; the app materialises it to /tmp on
# cold start (Vercel-friendly).
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Alternative: path to a SA JSON on disk (local dev).
# GOOGLE_APPLICATION_CREDENTIALS=

# Regions. Pass 1 in asia-south1 keeps audio in India for DPDP; Pass 2-5 are
# global Pro by default (no audio, transcript text only).
# VERTEX_FLASH_REGION=asia-south1
# VERTEX_PRO_REGION=global

# Models. Defaults are the best quality/cost balance for the scribe pipeline.
# Override to pin or downgrade for cost experiments.
# VERTEX_FLASH_MODEL=gemini-2.5-flash
# VERTEX_PRO_MODEL=gemini-2.5-pro

# Per-pass overrides. Each falls through to VERTEX_PRO_MODEL if unset.
# VERTEX_CLINICAL_MODEL=gemini-2.5-pro          # Pass 3 (Sprint 13)
# VERTEX_THERAPY_SCRIPT_MODEL=gemini-2.5-pro    # Pass 4 (Sprint 14)
# VERTEX_BRIEF_MODEL=gemini-2.5-pro             # Pass 5 (Sprint 17)

# Cost circuit breaker. Defaults are conservative; raise for power-pilot
# therapists who do >10 sessions/day.
# COST_CAP_PER_SESSION_INR=500
# COST_CAP_PER_THERAPIST_MONTHLY_INR=15000

# -----------------------------------------------------------------------------
# Firebase Auth — therapist phone OTP.
#
# Required to actually authenticate real therapists. If ANY of the three
# server-side vars are missing, the app auto-engages AUTH_BYPASS and routes
# every visitor to the seeded "dev-firebase-uid-priya" fixture.
# -----------------------------------------------------------------------------

# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# Newline-escaped (literal `\n` in the env value).
# FIREBASE_PRIVATE_KEY=

# Browser SDK config (NEXT_PUBLIC_*).
# NEXT_PUBLIC_FIREBASE_API_KEY=                 # (public)
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=             # (public)
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=              # (public)
# NEXT_PUBLIC_FIREBASE_APP_ID=                  # (public)

# Explicit opt-in (overrides the env-driven auto-bypass). Use in CI / when
# you want bypass even with Firebase env set.
# AUTH_BYPASS=false

# -----------------------------------------------------------------------------
# Patient PWA Firebase (separate project) — only needed once apps/client-web
# lands. Pre-pilot backlog item; not used by apps/web today.
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_FIREBASE_CLIENT_API_KEY=          # (public)
# NEXT_PUBLIC_FIREBASE_CLIENT_AUTH_DOMAIN=      # (public)
# NEXT_PUBLIC_FIREBASE_CLIENT_PROJECT_ID=       # (public)
# NEXT_PUBLIC_FIREBASE_CLIENT_APP_ID=           # (public)

# -----------------------------------------------------------------------------
# WebAuthn — Sprint 18 — note sign-off hardening.
# -----------------------------------------------------------------------------

# HMAC key for the stateless registration ticket (5-min TTL). Minimum 32 chars;
# generate with `openssl rand -base64 48`. Dev fallback exists in
# lib/webauthn-server.ts but is hardcoded — DO NOT rely on it in prod.
# WEBAUTHN_TICKET_SECRET=

# WEBAUTHN_RP_ID=app.cureocitymind.com          # defaults to request hostname
# WEBAUTHN_RP_NAME=Cureocity Mind
# Sprint 33 — comma-separated allowlist of clientData.origin values the
# note-signing assertion verifier accepts. Unset = origin check skipped
# (the authenticatorData rpIdHash binding is still enforced); set it in
# prod to pin the exact web origin(s).
# WEBAUTHN_ORIGINS=https://app.cureocitymind.com

# -----------------------------------------------------------------------------
# Patient sharing channels — Sprint 15.
#
# When unset, the share route falls back to the NoopBackend so dev still
# produces coherent PatientShare rows + provider message IDs. Real prod
# sends require these.
# -----------------------------------------------------------------------------

# WhatsApp via WATI. apiBase is region-specific (live-mt-server.wati.io).
# WATI_API_BASE=
# WATI_BEARER_TOKEN=
# Templates must be pre-approved by WhatsApp Business. The renewal one
# is consumed by the daily billing-reminders cron (Sprint 56).
# WATI_TEMPLATE_PATIENT_SHARE=patient_share
# WATI_TEMPLATE_RENEWAL_REMINDER=cureocity_renewal_reminder

# Email via SendGrid. fromEmail must be a verified sender on your SendGrid
# account.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Cureocity Mind

# -----------------------------------------------------------------------------
# Billing — Sprint 53. Razorpay Orders + Checkout (no SDK).
# -----------------------------------------------------------------------------

# Backend selector. 'mock' is the default and accepts only the literal
# signature 'mock-signature' on the webhook (CI/dev). 'razorpay' wires
# the real HTTP backend. The mock refuses to boot in production
# (VERCEL_ENV=production) unless BILLING_ALLOW_MOCK=true is also set.
# BILLING_BACKEND=razorpay
# BILLING_ALLOW_MOCK=

# Razorpay credentials. The webhook secret is configured in the
# Razorpay dashboard and used to verify x-razorpay-signature.
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Public key id shipped to the browser by /api/v1/billing/checkout so
# the inline PlanCheckoutButton can open Razorpay Checkout.
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx

# Plan prices in INR (whole rupees). Each overrides the matching
# PLAN_CATALOG default in packages/contracts/src/billing.ts (Sprint 56
# tier ladder) so prices can be A/B-tested without a deploy. Legacy
# SOLO_* remain for grandfathered payers.
# BILLING_PRICE_TRAINEE_MONTHLY_INR=499
# BILLING_PRICE_STARTER_MONTHLY_INR=1499
# BILLING_PRICE_STARTER_ANNUAL_INR=14990
# BILLING_PRICE_PRO_MONTHLY_INR=3499
# BILLING_PRICE_PRO_QUARTERLY_INR=9450
# BILLING_PRICE_PRO_ANNUAL_INR=34990
# BILLING_PRICE_PREMIUM_MONTHLY_INR=6999
# BILLING_PRICE_PREMIUM_ANNUAL_INR=69990
# BILLING_PRICE_SOLO_MONTHLY_INR=999
# BILLING_PRICE_SOLO_ANNUAL_INR=9990

# -----------------------------------------------------------------------------
# Cron / retention.
# -----------------------------------------------------------------------------

# Bearer token for /api/v1/cron/audio-retention. Vercel cron sets the
# Authorization header to "Bearer $CRON_SECRET"; the route rejects any
# other request.
# CRON_SECRET=

# Audio retention window (days). Sweeper deletes audio chunks older than this.
# AUDIO_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Affect engine — tunable thresholds for baseline + deviation detection.
# Defaults are sensible; only override after pilot data.
# -----------------------------------------------------------------------------

# AFFECT_BASELINE_MIN_SESSIONS=3
# AFFECT_BASELINE_WINDOW_SESSIONS=8
# AFFECT_DEVIATION_SIGMA=2

# -----------------------------------------------------------------------------
# Observability — OpenTelemetry. Disabled by default; wire in Sprint 18+
# once Sentry / OTel collector / Grafana are provisioned.
# -----------------------------------------------------------------------------

# OTEL_DISABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_PROMETHEUS_PORT=9464

# -----------------------------------------------------------------------------
# Local infrastructure (docker-compose). Only used by `pnpm infra:up` and the
# NestJS service scaffolds — apps/web does NOT use Redis / Kafka / MinIO in
# the live request path.
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379

# Kafka 3.7 KRaft via docker-compose. Host port 29092 reaches the broker from
# outside docker; in-docker apps use kafka:9092.
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=cureocity-mind

# MinIO for S3-compatible object storage. Production uses real S3 / GCS.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cureocity
S3_SECRET_KEY=cureocity-dev-secret
S3_BUCKET_AUDIO=cureocity-mind-audio
S3_BUCKET_PDFS=cureocity-mind-pdfs
S3_FORCE_PATH_STYLE=true

# Per-tenant PII envelope encryption — Sprint 32 Phase 1.
# KMS_BACKEND selects the KMS port: 'local-dev' (default) derives the master
# key from CRYPTO_DEV_MASTER_SECRET via scrypt for dev/CI; 'aws-kms' is
# reserved for S32 Phase 2 once @aws-sdk/client-kms is wired and the
# asia-south1 CMK is provisioned. Anything else hard-fails at first call.
KMS_BACKEND=local-dev
CRYPTO_DEV_MASTER_SECRET=local-dev-master-secret-do-not-use-in-prod

# -----------------------------------------------------------------------------
# Node + runtime.
# -----------------------------------------------------------------------------

NODE_ENV=development
# PORT=3000

# Verbose Gemini SDK logging — useful when debugging response shape.
# GEMINI_NEXT_GEN_API_LOG=true

# CI flag for integration tests that hit external infra.
# RUN_INTEGRATION_TESTS=false

# -----------------------------------------------------------------------------
# services/* scaffold only — NOT used by apps/web.
# Kept for parity with the NestJS service tree; only matters if you run the
# scaffold directly.
# -----------------------------------------------------------------------------

# GCP_PROJECT_ID=
# GCP_SA_KEY_PATH=
# STORAGE_BACKEND=s3
# NOTE_QUEUE_BACKEND=bullmq
# NOTE_QUEUE_NAME=note-generation

# Sprint 37 — pilot invite gate. When 'true', a new therapist's first
# sign-in requires a valid admin-minted invite code (mint at
# /app/admin/invite-codes). Unset/false keeps signup open.
# PILOT_INVITE_REQUIRED=false

# Sprint 40 — observability error forwarding. When set, captured server +
# client errors are POSTed as JSON to this URL (point it at Sentry ingest,
# an OTel collector, Axiom, Better Stack, a Slack relay — anything). Unset
# = errors are logged to stdout only (Vercel captures that).
# OBSERVABILITY_WEBHOOK_URL=
# OBSERVABILITY_WEBHOOK_TOKEN=
