# Database (Postgres 16 via docker-compose)
DATABASE_URL=postgresql://cureocity:cureocity@localhost:5432/cureocity_mind

# Cache & rate limiting (Redis 7 via docker-compose)
REDIS_URL=redis://localhost:6379

# Event bus (Kafka 3.7 KRaft via docker-compose)
# Host port 29092 reaches the broker from outside docker; in-docker apps use kafka:9092
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=cureocity-mind

# Object storage (MinIO locally; GCS in production)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cureocity
S3_SECRET_KEY=cureocity-dev-secret
S3_BUCKET_AUDIO=cureocity-mind-audio
S3_BUCKET_PDFS=cureocity-mind-pdfs
S3_FORCE_PATH_STYLE=true

# Node environment
NODE_ENV=development
