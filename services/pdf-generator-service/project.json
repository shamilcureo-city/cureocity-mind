{
  "name": "pdf-generator-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "services/pdf-generator-service/src",
  "projectType": "application",
  "tags": ["scope:backend", "type:service"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p tsconfig.build.json",
        "cwd": "services/pdf-generator-service"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "command": "tsc --noEmit", "cwd": "services/pdf-generator-service" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "eslint src test --max-warnings 0 --no-error-on-unmatched-pattern",
        "cwd": "services/pdf-generator-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": { "command": "vitest run", "cwd": "services/pdf-generator-service" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch src/main.ts",
        "cwd": "services/pdf-generator-service"
      }
    }
  }
}
