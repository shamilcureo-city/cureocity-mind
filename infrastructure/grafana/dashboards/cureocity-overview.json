{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 38,
  "title": "Cureocity Mind — overview",
  "uid": "cureocity-overview",
  "tags": ["cureocity", "overview"],
  "timezone": "Asia/Kolkata",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Crisis flags (last 24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(increase(crisis_flags_raised_total[24h]))" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Cost circuit trips (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(increase(cost_circuit_trips_total[24h]))" }]
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Audit writes / sec by action",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (action) (rate(audit_writes_total[5m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Gemini call duration p95 by pass",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, pass) (rate(gemini_call_duration_ms_bucket[5m])))",
          "legendFormat": "{{pass}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "HTTP request rate by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (service_name) (rate(http_server_duration_milliseconds_count[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Audio chunks uploaded / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (sample_rate_hz, size_bucket) (rate(audio_chunks_uploaded_total[5m]))",
          "legendFormat": "{{sample_rate_hz}}Hz / {{size_bucket}}"
        }
      ]
    }
  ]
}
