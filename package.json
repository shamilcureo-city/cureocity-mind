{
  "name": "cureocity-mind",
  "version": "0.0.0",
  "private": true,
  "description": "Ambient therapy scribe for Indian psychologists practising CBT and EMDR",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "infra:up": "docker compose -f infrastructure/docker-compose.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker-compose.yml down",
    "infra:logs": "docker compose -f infrastructure/docker-compose.yml logs -f",
    "gateway": "pnpm --filter @cureocity/live-gateway dev",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:validate": "prisma validate && prisma format --check",
    "db:check-migrations": "node scripts/check-migration-idempotency.mjs",
    "eval:reasoning": "pnpm --filter @cureocity/llm eval:reasoning"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "nx": "^20.2.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nx",
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "esbuild",
      "@firebase/util",
      "@nestjs/core",
      "protobufjs",
      "@swc/core"
    ]
  }
}
